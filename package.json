{
  "name": "zetapay",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --fix . && prettier --write .",
    "lint:rust": "cd contracts && cargo clippy --target wasm32-unknown-unknown -- -D warnings && cargo fmt --all -- --check",
    "prepare": "husky",
    "type-check": "tsc --noEmit",
    "precommit": "lint-staged",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "circuits:commitments": "node scripts/generate-commitment.js",
    "circuits:compile": "cd circuits/payroll && nargo compile",
    "circuits:execute": "cd circuits/payroll && nargo execute",
    "circuits:build": "bash scripts/build-payroll.sh",
    "circuits:prove": "npx ts-node scripts/generate-proof.ts",
    "circuits:export": "node scripts/export-payroll-fixtures.js",
    "circuits:test": "cd circuits/payroll && nargo test --show-output",
    "circuits:clean": "rm -rf circuits/payroll/target/*",
    "circuits:all": "yarn circuits:commitments && yarn circuits:clean && yarn circuits:test && yarn circuits:build && yarn circuits:prove && yarn circuits:export",
    "circuits:verify": "node scripts/verify-proof.js",
    "contracts:clean": "cd contracts && cargo clean",
    "contracts:build": "cd contracts && yarn contracts:clean && cargo build --target wasm32v1-none --release",
    "contracts:test": "cd contracts && yarn contracts:clean && cargo test",
    "contracts:deploy": "bash scripts/deploy-contracts.sh"
  },
  "dependencies": {
    "@noir-lang/backend_barretenberg": "0.34.0",
    "@noir-lang/noir_js": "0.34.0",
    "@noir-lang/noirc_abi": "0.34.0",
    "@stellar/freighter-api": "^6.0.1",
    "@stellar/stellar-sdk": "^16.0.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "circomlibjs": "^0.1.7",
    "drizzle-orm": "^0.45.2",
    "js-cookie": "^3.0.8",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "@types/prettier": "^3.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^6.0.3"
  }
}
